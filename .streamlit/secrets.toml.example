# Copy to secrets.toml (same folder) and fill in real values.
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# secrets.toml is gitignored — never commit it.
#
# Streamlit Community Cloud: paste the same key/value lines into
# your app → Settings → Secrets (no need for [section] headers).

PROSHORT_API_BEARER_TOKEN = "paste-token-here"
PROSHORT_MEETING_JOIN_BASE_URL = "https://your-public-api.example.com/enterprise-api-down"
